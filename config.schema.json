{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "embeddingModels": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": ["openai"]
          },
          "model": {
            "type": "string"
          },
          "baseUrl": {
            "type": "string",
            "format": "uri"
          },
          "apiKey": {
            "type": "string"
          },
          "dimensions": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": ["provider", "model", "apiKey", "dimensions"],
        "additionalProperties": false
      }
    },
    "defaultEmbeddingModelId": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["embeddingModels"],
  "additionalProperties": false
}
